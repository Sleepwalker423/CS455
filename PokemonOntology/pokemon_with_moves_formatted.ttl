###  http://www.semanticweb.org/giosu/ontologies/2025/5/pokemon-ontology-v2#PokemonMove
:PokemonMove rdf:type owl:Class .


###  http://www.semanticweb.org/giosu/ontologies/2025/5/pokemon-ontology-v2#PokemonTrainer
:PokemonTrainer rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://www.example.org/pokemon-ontology#Abra
<http://www.example.org/pokemon-ontology#Abra> rdf:type owl:NamedIndividual ,
                                                        <http://www.example.org/pokemon-ontology#PokemonSpecies> ,
                                                        <http://www.example.org/pokemon-ontology#PsychicTypePokemon> ;
                                               <http://www.example.org/pokemon-ontology#evolvesInto> <http://www.example.org/pokemon-ontology#Kadabra> ;
                                               <http://www.example.org/pokemon-ontology#hasEvolutionarySuccessor> <http://www.example.org/pokemon-ontology#Alakazam> ,
                                                                                                                  <http://www.example.org/pokemon-ontology#Kadabra> ;
                                               <http://www.example.org/pokemon-ontology#hasType> <http://www.example.org/pokemon-ontology#Psychic> ;
                                               :canLearnMove :Teleport ;
                                               <http://www.example.org/pokemon-ontology#pokedexNumber> 63 .


###  http://www.example.org/pokemon-ontology#Aerodactyl
<http://www.example.org/pokemon-ontology#Aerodactyl> rdf:type owl:NamedIndividual ,
                                                              <http://www.example.org/pokemon-ontology#FlyingTypePokemon> ,
                                                              <http://www.example.org/pokemon-ontology#PokemonSpecies> ,
                                                              <http://www.example.org/pokemon-ontology#RockTypePokemon> ;
                                                     <http://www.example.org/pokemon-ontology#hasType> <http://www.example.org/pokemon-ontology#Flying> ,
                                                                                                       <http://www.example.org/pokemon-ontology#Rock> ;
