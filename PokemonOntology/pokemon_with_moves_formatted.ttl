@prefix : <http://www.semanticweb.org/giosu/ontologies/2025/5/pokemon-ontology-v2#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/giosu/ontologies/2025/5/pokemon-ontology-v2#> .

<http://www.semanticweb.org/giosu/ontologies/2025/5/pokemon-ontology-v2> rdf:type owl:Ontology ;
                                                                          rdfs:comment "An ontology for Pokémon Generation 1, focusing on evolution and type effectiveness." .

#################################################################
#    Object Properties
#################################################################

###  http://www.example.org/pokemon-ontology#evolvesInto
<http://www.example.org/pokemon-ontology#evolvesInto> rdf:type owl:ObjectProperty ;
                                                      rdfs:subPropertyOf <http://www.example.org/pokemon-ontology#hasEvolutionarySuccessor> ;
                                                      rdf:type owl:AsymmetricProperty ,
                                                               owl:IrreflexiveProperty ;
                                                      rdfs:domain <http://www.example.org/pokemon-ontology#PokemonSpecies> ;
                                                      rdfs:range <http://www.example.org/pokemon-ontology#PokemonSpecies> ;
                                                      owl:propertyDisjointWith <http://www.example.org/pokemon-ontology#hasType> ;
                                                      rdfs:comment "Represents a direct, one-step evolution." .


###  http://www.example.org/pokemon-ontology#hasEvolutionarySuccessor
<http://www.example.org/pokemon-ontology#hasEvolutionarySuccessor> rdf:type owl:ObjectProperty ,
                                                                            owl:TransitiveProperty ;
                                                                   rdfs:domain <http://www.example.org/pokemon-ontology#PokemonSpecies> ;
                                                                   rdfs:range <http://www.example.org/pokemon-ontology#PokemonSpecies> ;
                                                                   rdfs:comment "Transitive closure of evolvesInto - represents all Pokemon reachable through evolution." .


###  http://www.example.org/pokemon-ontology#hasType
<http://www.example.org/pokemon-ontology#hasType> rdf:type owl:ObjectProperty ,
                                                           owl:AsymmetricProperty ,
                                                           owl:IrreflexiveProperty ;
                                                  rdfs:domain <http://www.example.org/pokemon-ontology#PokemonSpecies> ;
                                                  rdfs:range <http://www.example.org/pokemon-ontology#PokemonType> ;
                                                  rdfs:comment "Represents a Pokémon's type." .


###  http://www.example.org/pokemon-ontology#isImmuneTo
<http://www.example.org/pokemon-ontology#isImmuneTo> rdf:type owl:ObjectProperty ;
                                                     rdfs:domain <http://www.example.org/pokemon-ontology#PokemonType> ;
                                                     rdfs:range <http://www.example.org/pokemon-ontology#PokemonType> ;
                                                     rdfs:comment "A relationship where the domain type takes no damage from the range type." .


###  http://www.example.org/pokemon-ontology#isStrongAgainst
<http://www.example.org/pokemon-ontology#isStrongAgainst> rdf:type owl:ObjectProperty ;
                                                          owl:inverseOf <http://www.example.org/pokemon-ontology#isWeakTo> ;
                                                          rdfs:domain <http://www.example.org/pokemon-ontology#PokemonType> ;
                                                          rdfs:range <http://www.example.org/pokemon-ontology#PokemonType> ;
                                                          rdfs:comment "A relationship where the domain type deals super-effective damage to the range type." .


###  http://www.example.org/pokemon-ontology#isWeakTo
<http://www.example.org/pokemon-ontology#isWeakTo> rdf:type owl:ObjectProperty ;
                                                   rdfs:domain <http://www.example.org/pokemon-ontology#PokemonType> ;
                                                   rdfs:range <http://www.example.org/pokemon-ontology#PokemonType> ;
                                                   rdfs:comment "A relationship where the domain type takes super-effective damage from the range type." .


###  http://www.semanticweb.org/giosu/ontologies/2025/5/pokemon-ontology-v2#canLearnMove
:canLearnMove rdf:type owl:ObjectProperty ;
              rdfs:domain <http://www.example.org/pokemon-ontology#PokemonSpecies> ;
              rdfs:range :PokemonMove .


###  http://www.semanticweb.org/giosu/ontologies/2025/5/pokemon-ontology-v2#hasMoveType
:hasMoveType rdf:type owl:ObjectProperty ;
             rdfs:domain :PokemonMove ;
             rdfs:range <http://www.example.org/pokemon-ontology#PokemonType> .


###  http://www.semanticweb.org/giosu/ontologies/2025/5/pokemon-ontology-v2#hasPokemon
:hasPokemon rdf:type owl:ObjectProperty ;
            rdfs:domain :PokemonTrainer ;
            rdfs:range <http://www.example.org/pokemon-ontology#PokemonSpecies> .


#################################################################
#    Data properties
#################################################################

###  http://www.example.org/pokemon-ontology#pokedexNumber
<http://www.example.org/pokemon-ontology#pokedexNumber> rdf:type owl:DatatypeProperty ,
                                                                 owl:FunctionalProperty ;
                                                        rdfs:domain <http://www.example.org/pokemon-ontology#PokemonSpecies> ;
                                                        rdfs:range xsd:positiveInteger ;
                                                        rdfs:comment "The unique Pokedex number assigned to each Pokemon species." .


#################################################################
#    Classes
#################################################################

###  http://www.example.org/pokemon-ontology#BugTypePokemon
<http://www.example.org/pokemon-ontology#BugTypePokemon> rdf:type owl:Class ;
                                                         owl:equivalentClass [ owl:intersectionOf ( <http://www.example.org/pokemon-ontology#PokemonSpecies>
                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                      owl:onProperty <http://www.example.org/pokemon-ontology#hasType> ;
                                                                                                      owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                                           owl:oneOf ( <http://www.example.org/pokemon-ontology#Bug>
                                                                                                                                     )
                                                                                                                         ]
                                                                                                    ]
                                                                                                  ) ;
                                                                               rdf:type owl:Class
                                                                             ] ;
                                                         rdfs:subClassOf <http://www.example.org/pokemon-ontology#PokemonSpecies> ;
                                                         owl:disjointWith <http://www.example.org/pokemon-ontology#PokemonType> ;
                                                         rdfs:comment "Pokemon that have Bug type." .


###  http://www.example.org/pokemon-ontology#DragonTypePokemon
<http://www.example.org/pokemon-ontology#DragonTypePokemon> rdf:type owl:Class ;
                                                            owl:equivalentClass [ owl:intersectionOf ( <http://www.example.org/pokemon-ontology#PokemonSpecies>
                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                         owl:onProperty <http://www.example.org/pokemon-ontology#hasType> ;
                                                                                                         owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                                              owl:oneOf ( <http://www.example.org/pokemon-ontology#Dragon>
                                                                                                                                        )
                                                                                                                            ]
                                                                                                       ]
                                                                                                     ) ;
                                                                                  rdf:type owl:Class
                                                                                ] ;
                                                            rdfs:subClassOf <http://www.example.org/pokemon-ontology#PokemonSpecies> ;
                                                            owl:disjointWith <http://www.example.org/pokemon-ontology#PokemonType> ;
                                                            rdfs:comment "Pokemon that have Dragon type." .


###  http://www.example.org/pokemon-ontology#ElectricTypePokemon
<http://www.example.org/pokemon-ontology#ElectricTypePokemon> rdf:type owl:Class ;
                                                              owl:equivalentClass [ owl:intersectionOf ( <http://www.example.org/pokemon-ontology#PokemonSpecies>
                                                                                                         [ rdf:type owl:Restriction ;
                                                                                                           owl:onProperty <http://www.example.org/pokemon-ontology#hasType> ;
                                                                                                           owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                                                owl:oneOf ( <http://www.example.org/pokemon-ontology#Electric>
                                                                                                                                          )
                                                                                                                              ]
                                                                                                         ]
                                                                                                       ) ;
                                                                                    rdf:type owl:Class
                                                                                  ] ;
                                                              rdfs:subClassOf <http://www.example.org/pokemon-ontology#PokemonSpecies> ;
                                                              owl:disjointWith <http://www.example.org/pokemon-ontology#PokemonType> ;
                                                              rdfs:comment "Pokemon that have Electric type." .


###  http://www.example.org/pokemon-ontology#EvolvedPokemon
<http://www.example.org/pokemon-ontology#EvolvedPokemon> rdf:type owl:Class ;
                                                         owl:equivalentClass [ owl:intersectionOf ( <http://www.example.org/pokemon-ontology#PokemonSpecies>
                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                      owl:onProperty [ owl:inverseOf <http://www.example.org/pokemon-ontology#evolvesInto>
                                                                                                                     ] ;
                                                                                                      owl:someValuesFrom <http://www.example.org/pokemon-ontology#PokemonSpecies>
                                                                                                    ]
                                                                                                  ) ;
                                                                               rdf:type owl:Class
                                                                             ] ;
                                                         rdfs:subClassOf <http://www.example.org/pokemon-ontology#PokemonSpecies> ;
                                                         owl:disjointWith <http://www.example.org/pokemon-ontology#PokemonType> ;
                                                         rdfs:comment "A Pokémon that has at least one predecessor." .


###  http://www.example.org/pokemon-ontology#FightTypePokemon
<http://www.example.org/pokemon-ontology#FightTypePokemon> rdf:type owl:Class ;
                                                           owl:equivalentClass [ owl:intersectionOf ( <http://www.example.org/pokemon-ontology#PokemonSpecies>
                                                                                                      [ rdf:type owl:Restriction ;
                                                                                                        owl:onProperty <http://www.example.org/pokemon-ontology#hasType> ;
                                                                                                        owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                                             owl:oneOf ( <http://www.example.org/pokemon-ontology#Fight>
                                                                                                                                       )
                                                                                                                           ]
                                                                                                      ]
                                                                                                    ) ;
                                                                                 rdf:type owl:Class
                                                                               ] ;
                                                           rdfs:subClassOf <http://www.example.org/pokemon-ontology#PokemonSpecies> ;
                                                           owl:disjointWith <http://www.example.org/pokemon-ontology#PokemonType> ;
                                                           rdfs:comment "Pokemon that have Fight type." .


###  http://www.example.org/pokemon-ontology#FireTypePokemon
<http://www.example.org/pokemon-ontology#FireTypePokemon> rdf:type owl:Class ;
                                                          owl:equivalentClass [ owl:intersectionOf ( <http://www.example.org/pokemon-ontology#PokemonSpecies>
                                                                                                     [ rdf:type owl:Restriction ;
                                                                                                       owl:onProperty <http://www.example.org/pokemon-ontology#hasType> ;
                                                                                                       owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                                            owl:oneOf ( <http://www.example.org/pokemon-ontology#Fire>
                                                                                                                                      )
                                                                                                                          ]
                                                                                                     ]
                                                                                                   ) ;
                                                                                rdf:type owl:Class
                                                                              ] ;
                                                          rdfs:subClassOf <http://www.example.org/pokemon-ontology#PokemonSpecies> ;
                                                          owl:disjointWith <http://www.example.org/pokemon-ontology#PokemonType> ;
                                                          rdfs:comment "Pokemon that have Fire type." .


###  http://www.example.org/pokemon-ontology#FlyingTypePokemon
<http://www.example.org/pokemon-ontology#FlyingTypePokemon> rdf:type owl:Class ;
                                                            owl:equivalentClass [ owl:intersectionOf ( <http://www.example.org/pokemon-ontology#PokemonSpecies>
                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                         owl:onProperty <http://www.example.org/pokemon-ontology#hasType> ;
                                                                                                         owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                                              owl:oneOf ( <http://www.example.org/pokemon-ontology#Flying>
                                                                                                                                        )
                                                                                                                            ]
                                                                                                       ]
                                                                                                     ) ;
                                                                                  rdf:type owl:Class
                                                                                ] ;
                                                            rdfs:subClassOf <http://www.example.org/pokemon-ontology#PokemonSpecies> ;
