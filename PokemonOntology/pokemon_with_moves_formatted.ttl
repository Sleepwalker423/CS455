<http://www.example.org/pokemon-ontology#WaterTypePokemon> rdf:type owl:Class ;
                                                           owl:equivalentClass [ owl:intersectionOf ( <http://www.example.org/pokemon-ontology#PokemonSpecies>
                                                                                                      [ rdf:type owl:Restriction ;
                                                                                                        owl:onProperty <http://www.example.org/pokemon-ontology#hasType> ;
                                                                                                        owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                                             owl:oneOf ( <http://www.example.org/pokemon-ontology#Water>
