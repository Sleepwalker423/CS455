                                                                                                                           owl:oneOf ( <http://www.example.org/pokemon-ontology#Ice>
                                                                                                                                     )
                                                                                                                         ]
                                                                                                    ]
                                                                                                  ) ;
                                                                               rdf:type owl:Class
                                                                             ] ;
                                                         rdfs:subClassOf <http://www.example.org/pokemon-ontology#PokemonSpecies> ;
                                                         owl:disjointWith <http://www.example.org/pokemon-ontology#PokemonType> ;
                                                         rdfs:comment "Pokemon that have Ice type." .


###  http://www.example.org/pokemon-ontology#NormalTypePokemon
<http://www.example.org/pokemon-ontology#NormalTypePokemon> rdf:type owl:Class ;
                                                            owl:equivalentClass [ owl:intersectionOf ( <http://www.example.org/pokemon-ontology#PokemonSpecies>
                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                         owl:onProperty <http://www.example.org/pokemon-ontology#hasType> ;
                                                                                                         owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                                              owl:oneOf ( <http://www.example.org/pokemon-ontology#Normal>
                                                                                                                                        )
                                                                                                                            ]
                                                                                                       ]
                                                                                                     ) ;
                                                                                  rdf:type owl:Class
                                                                                ] ;
                                                            rdfs:subClassOf <http://www.example.org/pokemon-ontology#PokemonSpecies> ;
                                                            owl:disjointWith <http://www.example.org/pokemon-ontology#PokemonType> ;
                                                            rdfs:comment "Pokemon that have Normal type." .


###  http://www.example.org/pokemon-ontology#PoisonTypePokemon
<http://www.example.org/pokemon-ontology#PoisonTypePokemon> rdf:type owl:Class ;
                                                            owl:equivalentClass [ owl:intersectionOf ( <http://www.example.org/pokemon-ontology#PokemonSpecies>
                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                         owl:onProperty <http://www.example.org/pokemon-ontology#hasType> ;
                                                                                                         owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                                              owl:oneOf ( <http://www.example.org/pokemon-ontology#Poison>
                                                                                                                                        )
                                                                                                                            ]
                                                                                                       ]
                                                                                                     ) ;
                                                                                  rdf:type owl:Class
                                                                                ] ;
                                                            rdfs:subClassOf <http://www.example.org/pokemon-ontology#PokemonSpecies> ;
                                                            owl:disjointWith <http://www.example.org/pokemon-ontology#PokemonType> ;
                                                            rdfs:comment "Pokemon that have Poison type." .


###  http://www.example.org/pokemon-ontology#PokemonSpecies
<http://www.example.org/pokemon-ontology#PokemonSpecies> rdf:type owl:Class ;
                                                         rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                           owl:onProperty [ owl:inverseOf <http://www.example.org/pokemon-ontology#evolvesInto>
                                                                                          ] ;
                                                                           owl:allValuesFrom <http://www.example.org/pokemon-ontology#PokemonSpecies>
                                                                         ] ;
                                                         owl:disjointWith <http://www.example.org/pokemon-ontology#PokemonType> ;
                                                         rdfs:comment "A generic Pokémon species." .


###  http://www.example.org/pokemon-ontology#PokemonType
<http://www.example.org/pokemon-ontology#PokemonType> rdf:type owl:Class ;
                                                      owl:disjointWith <http://www.example.org/pokemon-ontology#PsychicTypePokemon> ,
                                                                       <http://www.example.org/pokemon-ontology#RockTypePokemon> ,
                                                                       <http://www.example.org/pokemon-ontology#WaterTypePokemon> ;
                                                      rdfs:comment "A Pokémon type." .


###  http://www.example.org/pokemon-ontology#PsychicTypePokemon
<http://www.example.org/pokemon-ontology#PsychicTypePokemon> rdf:type owl:Class ;
